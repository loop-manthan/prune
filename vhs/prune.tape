Output vhs/prune.gif

Set Shell "bash"
Set FontSize 22
Set Width 180
Set Height 56
Set Theme "Dracula"
Set Padding 1
Set Framerate 60
Set TypingSpeed 40ms

Type "go run ./cmd/prune"
Enter

Sleep 2
Type "1"
Sleep 2
Type "2"
Sleep 2
Type "3"
Sleep 2
Type "4"
Sleep 2
Type "5"
Sleep 2
Type "6"
Sleep 2

Right
Sleep 1.5
Right
Sleep 1.5
Left
Sleep 1.5

Type "q"
Sleep 0.5
